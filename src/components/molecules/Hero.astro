---
interface Props {
  class?: string;
}

import Button from '../atoms/Button.astro';

const { class: extraClass = '' } = Astro.props;
---

<section
  class={`py-16 md:py-20 flex flex-col md:flex-row gap-10 md:gap-16 px-4 md:px-5 ${extraClass}`}
>
  <div class="flex flex-col gap-5 md:w-1/2">
    <h1 class="text-[#4E6273]">Meistern Sie das Bridgespiel</h1>
    <p class="text-4xl font-black leading-tight md:text-5xl">
      Bridge spielen mit Leidenschaft.
    </p>
    <p class="text-lg text-gray-700 md:text-xl">
      Werden Sie Teil einer erstklassigen Bridge-Community in Lübeck. Von
      Anfängerkursen bis zu fortgeschrittenen Strategien, finden Sie Ihren Platz
      am Tisch mit Eleganz und Fachwissen.
    </p>
    <Button text="Mehr erfahren" href="/news" />
  </div>

  <div class="flex items-center justify-center p-6 md:w-1/2 md:p-10">
    <div class="relative group">
      <div
        class="absolute -top-6 -left-10 text-4xl bg-[#F396E5] px-4 py-1 z-10 rounded-t-2xl border-[3px] border-black shadow-[4px_4px_0_#000] group-hover:shadow-[10px_10px_0_#000] transition"
      >
        ♣
      </div>
      <div
        class="absolute top-10 -right-10 text-4xl bg-[#F2CF96] p-2 z-10 rounded-full border-[3px] border-black shadow-[4px_4px_0_#000] group-hover:shadow-[10px_10px_0_#000] transition"
      >
        ♥
      </div>
      <div
        class="bg-[#96C7F2] border-[3px] border-black rounded-2xl w-72 h-72 md:w-80 md:h-80 shadow-[4px_4px_0_#000] group-hover:shadow-[10px_10px_0_#000] transition relative overflow-hidden"
      >
        <div
          class="absolute inset-0 bg-center bg-cover"
          style="background-image:url('/grandma_playing_bridge_online.webp')"
        >
        </div>
      </div>
      <div
        class="absolute -bottom-6 right-0 bg-[#ADF296] border-[3px] border-black rounded-full px-3 py-1 shadow-[2px_2px_0_#000]"
      >
        <span class="text-sm">Bridge mit Alexander</span>
      </div>
    </div>
  </div>
</section>
