---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import MarkdownContent from '../../components/molecules/MarkdownContent.astro';
import Layout from '../../layouts/Layout.astro';
import { getEntrySlug } from '../../lib/contentSlug';
export const prerender = true;

export async function getStaticPaths() {
  const holidays = await getCollection('holiday');
  return holidays.map((holiday) => {
    return {
      params: { slug: getEntrySlug(holiday, 'holiday') },
      props: { holiday },
    };
  });
}

type Props = { holiday: CollectionEntry<'holiday'> };
const { holiday } = Astro.props as Props;
const { Content } = await render(holiday);
---

<Layout title={`${holiday.data.title} - Bridge-Reisen`}>
  <section class="section">
    <MarkdownContent
      title={holiday.data.title}
      dateRange={{
        start: holiday.data.start_date,
        end: holiday.data.end_date,
      }}
      image={holiday.data.image}
      backLink="/holiday"
      backText="← Zurück zu Reisen"
    >
      <Content />
    </MarkdownContent>
  </section>
</Layout>
