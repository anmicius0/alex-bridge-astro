---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import MarkdownContent from '../../components/molecules/MarkdownContent.astro';
import Layout from '../../layouts/Layout.astro';
import { getEntrySlug } from '../../lib/contentSlug';
export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('news');
  return posts.map((post) => {
    return {
      params: { slug: getEntrySlug(post) },
      props: { post },
    };
  });
}

type Props = { post: CollectionEntry<'news'> };
const { post } = Astro.props as Props;
const { Content } = await render(post);
---

<Layout title={`${post.data.title} - Bridge mit Alexander`}>
  <section class="section">
    <MarkdownContent
      title={post.data.title}
      date={post.data.date}
      backLink="/news"
      backText="← Zurück zu News"
    >
      <Content />
    </MarkdownContent>
  </section>
</Layout>
