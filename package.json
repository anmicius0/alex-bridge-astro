{
  "name": "alex-bridge-astro",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"bun run astro:dev\" \"bun run sass:watch\"",
    "astro:dev": "astro dev",
    "sass:watch": "sass --watch --load-path=node_modules src/styles/global.scss src/styles/global.css",
    "build": "bun run sass:build && astro build",
    "sass:build": "sass --load-path=node_modules src/styles/global.scss src/styles/global.css",
    "preview": "astro preview",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/preact": "^4.1.1",
    "@astrojs/react": "^4.4.0",
    "@astrojs/vercel": "^8.2.11",
    "@auth/core": "^0.41.0",
    "@eslint/js": "^9.38.0",
    "@fullcalendar/core": "^6.1.19",
    "@fullcalendar/daygrid": "^6.1.19",
    "@fullcalendar/list": "^6.1.19",
    "@fullcalendar/react": "^6.1.19",
    "@fullcalendar/timegrid": "^6.1.19",
    "@tailwindcss/vite": "^4.1.15",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "astro": "^5.14.7",
    "auth-astro": "^4.2.0",
    "decap-cms-app": "^3.8.4",
    "eslint": "^9.38.0",
    "eslint-plugin-astro": "^1.3.1",
    "node-ical": "^0.22.0",
    "preact": "^10.27.2",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "remixicon": "^4.7.0",
    "sass": "^1.93.2",
    "tailwindcss": "^4.1.15",
    "typescript-eslint": "^8.46.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "sass-embedded": "^1.93.2"
  }
}
